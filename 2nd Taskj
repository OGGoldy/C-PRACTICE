#include <iostream>
using namespace std;
int main() {
    int n;
    cout << "Enter Number of corners: ";
    cin >> n;
    int angles[n];
    int sum = 0;
    for(int i = 0; i < n; i++) {
        cout << "Corner " << i + 1 << ": ";
        cin >> angles[i];
        sum += angles[i];
    }
    if(sum == 180 * (n - 2))
        cout << "This polygon is existє";
    else
        cout << "There is no polygon";
    return 0;
}
