#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;
int main() {
    const int SIZE = 10;
    int arr[SIZE];
    int even = 0, odd = 0;
    srand(time(0));
    for(int i = 0; i < SIZE; i++) {
        arr[i] = rand() % 100;
        cout << arr[i] << " ";
        if(arr[i] % 2 == 0)
            even++;
        else
            odd++;
    }
    cout << "\nparnyh: " << even;
    cout << "\nNe parnyh: " << odd;
    return 0;
}
